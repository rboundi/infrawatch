# ──────────────────────────────────────────────
# InfraWatch — Production Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Run: cp .env.production.example .env

# ── Database ──
DB_NAME=infrawatch
DB_USER=infrawatch
# REQUIRED — auto-generated by setup.sh if empty
DB_PASSWORD=

# ── Encryption ──
# REQUIRED — auto-generated by setup.sh if empty
# Used to encrypt stored credentials (SSH keys, passwords)
MASTER_KEY=

# ── Web ──
# Host port for the web UI
WEB_PORT=80

# ── SMTP (optional — for alert email digests) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Alert recipient email ──
ALERT_EMAIL=

# CORS origin — the URL where the web UI is served
CORS_ORIGIN=http://localhost

# ── Tuning ──
VERSION_CHECK_INTERVAL_HOURS=12
ALERT_DIGEST_HOUR=8
