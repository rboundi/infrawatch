{
  "name": "@infrawatch/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node-pg-migrate up --migrations-dir migrations --envPath ../../.env",
    "db:migrate:create": "node-pg-migrate create --migrations-dir migrations -j cjs",
    "db:migrate:down": "node-pg-migrate down --migrations-dir migrations --envPath ../../.env"
  },
  "dependencies": {
    "@infrawatch/scanner": "*",
    "express": "^4.21.0",
    "express-validator": "^7.3.1",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "semver": "^6.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.0",
    "@types/semver": "^7.7.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
