{
  "name": "@infrawatch/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node-pg-migrate up --migrations-dir migrations --envPath ../../.env",
    "db:migrate:create": "node-pg-migrate create --migrations-dir migrations -j cjs",
    "db:migrate:down": "node-pg-migrate down --migrations-dir migrations --envPath ../../.env"
  },
  "dependencies": {
    "@infrawatch/scanner": "*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "puppeteer": "^24.40.0",
    "semver": "^6.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.0",
    "@types/semver": "^7.7.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
